<Window x:Class="WindowsClient.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Client"
        Height="720"
        Width="1180"
        MinHeight="640"
        MinWidth="1024">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.RowSpan="3" Padding="12" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Profiles" />
                    <TextBlock Foreground="#57606A" Text="Saved configs, one active connection at a time" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Width="72" Margin="0,0,8,0" Content="New" Command="{Binding NewProfileCommand}" />
                    <Button Width="72" Margin="0,0,8,0" Content="Edit" Command="{Binding EditProfileCommand}" />
                    <Button Width="72" Content="Delete" Command="{Binding DeleteProfileCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="0,0,0,8" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Foreground="#57606A" Text="{Binding Community}" />
                                    <TextBlock Foreground="#57606A" Text="{Binding SupernodeHost}" />
                                    <TextBlock Foreground="#57606A" Text="{Binding EdgeVersionId}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Grid.Row="0" Padding="16" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Connection Console" />
                    <TextBlock Margin="0,4,0,0" Foreground="#57606A" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                    <UniformGrid Margin="0,12,0,0" Columns="2">
                        <TextBlock FontWeight="SemiBold" Text="Active profile" />
                        <TextBlock Text="{Binding ActiveProfileName}" />
                        <TextBlock FontWeight="SemiBold" Text="Selected version" />
                        <TextBlock Text="{Binding SelectedVersionName}" />
                        <TextBlock FontWeight="SemiBold" Text="Resolved path" />
                        <TextBlock Text="{Binding ResolvedBinaryPath}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="State" />
                        <TextBlock Text="{Binding CurrentStatus}" />
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Width="92" Margin="0,0,8,0" Content="Connect" Command="{Binding ConnectSelectedCommand}" />
                    <Button Width="92" Margin="0,0,8,0" Content="Disconnect" Command="{Binding DisconnectCommand}" />
                    <Button Width="92" Content="Reconnect" Command="{Binding ReconnectCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Column="2" Grid.Row="2">
            <TabItem Header="Logs">
                <Grid Margin="12">
                    <TextBox IsReadOnly="True" Text="{Binding LogsText}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="Diagnostics">
                <Grid Margin="12">
                    <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Diagnostics}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                            <DataGridTextColumn Header="Suggestion" Binding="{Binding Suggestion}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Profile Details">
                <Grid Margin="12">
                    <TextBox IsReadOnly="True" Text="{Binding ProfileDetailsText}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
